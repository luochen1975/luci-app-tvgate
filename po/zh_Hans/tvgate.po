# Web config page descriptions
msgid "Enable the Web management interface"
msgstr "启用 Web 管理接口"

msgid "Username to log into the management page"
msgstr "用于登录管理页面的用户名"

msgid "Password to log into the management page"
msgstr "用于登录管理页面的密码"

msgid "Web path prefix, e.g., /web/"
msgstr "Web 管理前缀路径，例如 /web/"

msgid "Streaming port in server section"
msgstr "服务监听端口（位于 server 分节）"

msgid "Monitor endpoint path, e.g., /status"
msgstr "状态接口路径，例如 /status"

msgid "Enable log output"
msgstr "是否启用日志输出"

msgid "Empty for stdout, otherwise file path"
msgstr "留空表示标准输出，否则写入指定文件路径"

msgid "Rotate when max size reached (MB)"
msgstr "达到大小后进行轮转"

msgid "Number of compressed backups to keep"
msgstr "保留的压缩备份文件数量"

msgid "Retention days for log files"
msgstr "日志文件保留的天数"

msgid "Compress rotated log files"
msgstr "是否压缩轮转产生的日志文件"

# Multicast config page labels
msgid "Multicast / FCC Config"
msgstr "组播 / FCC 配置"

msgid "Multicast Listen Interfaces"
msgstr "组播监听接口"

msgid "Add Interface"
msgstr "添加接口"

msgid "Multicast Rejoin Interval"
msgstr "多播重新加入间隔"

msgid "FCC Type"
msgstr "FCC 类型"

msgid "Telecom / ZTE / FiberHome"
msgstr "电信/中兴/烽火"

msgid "Huawei"
msgstr "华为"

msgid "FCC Cache Size"
msgstr "FCC 缓存大小"

msgid "FCC Listen Port Range"
msgstr "FCC 监听端口范围"

msgid "Generic Upstream Interface"
msgstr "通用上游接口"

msgid "FCC Dedicated Upstream Interface"
msgstr "FCC 专用上游接口"

msgid "Delete"
msgstr "删除"

# Multicast config page descriptions
msgid "Network interfaces used to receive multicast traffic. Leave empty to use the default interface."
msgstr "用于接收组播流量的网络接口列表，留空表示使用默认接口"

msgid "Multicast rejoin interval, for example 10s. Set to 0s to disable."
msgstr "多播重新加入间隔时间，例如 10s。设置为 0s 表示禁用"

msgid "Select the FCC protocol type"
msgstr "选择 FCC 协议类型"

msgid "Number of packets in the FCC cache"
msgstr "FCC 缓存的数据包数量"

msgid "FCC listen port range (min - max)"
msgstr "FCC 监听端口范围（最小值 - 最大值）"

msgid "Generic upstream interface for multicast and non-FCC connections (optional)"
msgstr "通用上游接口，用于多播和非 FCC 连接（可选）"

msgid "Dedicated upstream interface for FCC. Higher priority than the generic interface. Leave empty to use the generic interface."
msgstr "FCC 专用上游接口，优先级高于通用接口。留空则使用通用接口"
