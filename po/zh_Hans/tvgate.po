# Overview page
msgid "Overview"
msgstr "概览"

msgid "How to use"
msgstr "使用方法"

msgid "Forward internal network resources (such as http, https, rtsp, rtp) to the external network through HTTP"
msgstr "通过 HTTP 将内网资源（如 http、https、rtsp、rtp）转发到外网"

msgid "Support multicast, unicast audio and video streams converted to HTTP accessible links"
msgstr "支持多播、单播音视频流转换为可通过 HTTP 访问的链接"

msgid "Built-in Web management interface for visual configuration"
msgstr "内置 Web 管理界面，支持可视化配置"

msgid "Support Docker deployment, systemd service management and OpenWrt system integration"
msgstr "支持 Docker 部署、systemd 服务管理以及 OpenWrt 系统集成"

msgid "Usage instructions"
msgstr "使用说明"

msgid "Configure the download proxy (e.g., https://hk.gh-proxy.com/) to speed up downloads"
msgstr "配置下载代理（例如 https://hk.gh-proxy.com/）以加速下载"

msgid "Click \"Download/Update Binary\" to download the TVGate executable"
msgstr "点击"下载/更新二进制"以下载 TVGate 可执行文件"

msgid "Enable the service and apply the settings"
msgstr "启用服务并应用设置"

msgid "Access the web interface at http://[router-ip]:[streaming-port]/web/ to manage settings"
msgstr "通过 http://[路由器IP]:[端口]/web/ 访问管理界面进行配置"

msgid "Access IPTV streams at http://[router-ip]:[streaming-port]/channel-url"
msgstr "通过 http://[路由器IP]:[端口]/频道地址 访问 IPTV 流"

msgid "Monitor service status at http://[router-ip]:[streaming-port]/status"
msgstr "通过 http://[路由器IP]:[端口]/status 监控服务状态"

msgid "Web Management"
msgstr "Web 管理"

msgid "Monitoring"
msgstr "监控"

msgid "Streaming Port"
msgstr "流媒体端口"

